#!/command/with-contenv sh
# shellcheck shell=sh

set -eou pipefail

# Configure all variables to be exported to be readable by configgen
set -o allexport

echo "Starting xray config..."

mkdir -p "${GENERATED_CONFIG_PATH}"

# Check if our xray config file exists
if [ ! -f "${XRAY_CONFIG}" ]; then
    echo "${XRAY_CONFIG} not found, building a new config"

    XRAY_UUID=$(xray uuid)
    XRAY_REALITY_SHORT_ID=$(head -c 8 /dev/urandom | od -An -tx1 | tr -d ' \n')

    # Extract keys with awk '{print $NF}' (last field) rather than `cut -f2`:
    # `xray x25519` prints "Password (PublicKey): <key>", so the key is the last
    # token, not the second. $NF works for both the old and new output formats.
    xray_keys=$(xray x25519)
    XRAY_REALITY_PRIVATE_KEY=$(echo "${xray_keys}" | grep 'PrivateKey' | awk '{print $NF}')
    XRAY_REALITY_PUBLIC_KEY=$(echo "${xray_keys}" | grep 'Password' | awk '{print $NF}')

    # VLESS Encryption ("Seed") keypair, post-quantum ML-KEM-768. Independent
    # from the REALITY keypair above (which must stay X25519): REALITY secures the
    # outer transport handshake, this secures the inner VLESS proxy layer. The
    # server uses the ML-KEM seed in "decryption", clients use the ML-KEM
    # encapsulation key ("Client") in "encryption".
    # `xray mlkem768` prints "Seed: <key>" / "Client: <key>" / "Hash32: <key>".
    xray_vless_enc_keys=$(xray mlkem768)
    XRAY_VLESS_ENC_SEED=$(echo "${xray_vless_enc_keys}" | grep 'Seed' | awk '{print $NF}')
    XRAY_VLESS_ENC_CLIENT=$(echo "${xray_vless_enc_keys}" | grep 'Client' | awk '{print $NF}')

    {
        echo "XRAY_UUID=${XRAY_UUID}"
        echo "XRAY_REALITY_SHORT_ID=${XRAY_REALITY_SHORT_ID}"
        echo "XRAY_REALITY_PRIVATE_KEY=${XRAY_REALITY_PRIVATE_KEY}"
        echo "XRAY_REALITY_PUBLIC_KEY=${XRAY_REALITY_PUBLIC_KEY}"
        echo "XRAY_VLESS_ENC_SEED=${XRAY_VLESS_ENC_SEED}"
        echo "XRAY_VLESS_ENC_CLIENT=${XRAY_VLESS_ENC_CLIENT}"
    } > "${XRAY_CONFIG}"
fi

{
    echo "XRAY_XHTTP_PATH=${XRAY_PATH}/xhttp"
} > "${XRAY_RUNTIME_CONFIG}"

# shellcheck disable=SC1090
. "${XRAY_CONFIG}"
# shellcheck disable=SC1090
. "${XRAY_RUNTIME_CONFIG}"

# Migrate key files created before VLESS Encryption was introduced: generate the
# keypair once and append it so existing deployments keep stable keys.
if [ -z "${XRAY_VLESS_ENC_SEED:-}" ] || [ -z "${XRAY_VLESS_ENC_CLIENT:-}" ]; then
    echo "VLESS Encryption keys not found in ${XRAY_CONFIG}, generating..."
    xray_vless_enc_keys=$(xray mlkem768)
    XRAY_VLESS_ENC_SEED=$(echo "${xray_vless_enc_keys}" | grep 'Seed' | awk '{print $NF}')
    XRAY_VLESS_ENC_CLIENT=$(echo "${xray_vless_enc_keys}" | grep 'Client' | awk '{print $NF}')
    {
        echo "XRAY_VLESS_ENC_SEED=${XRAY_VLESS_ENC_SEED}"
        echo "XRAY_VLESS_ENC_CLIENT=${XRAY_VLESS_ENC_CLIENT}"
    } >> "${XRAY_CONFIG}"
fi

# Build the client-side VLESS Encryption string ("Seed"). Format:
#   mlkem768x25519plus.<xormode>.<rtt>.<ML-KEM-768 encapsulation key>
# Authentication is post-quantum ML-KEM-768 (the "Client" key from `xray
# mlkem768`); the ephemeral key exchange is also ML-KEM-768 + X25519 hybrid, so
# the whole session is post-quantum-safe. Use "0rtt" so the client resumes via
# short-lived tickets when it can and falls back to a full handshake otherwise.
# Must stay in sync with the server's "600s" decryption in the xray service.
XRAY_VLESS_ENCRYPTION="mlkem768x25519plus.native.0rtt.${XRAY_VLESS_ENC_CLIENT}"

echo "Building xray client configs..."

if [ -z "${XHTTP_SELF_DOMAIN:-}" ]; then
    echo "XHTTP_SELF_DOMAIN must be set for the xhttp_self client profile" >&2
    exit 1
fi

# Get public IP
if [ -z "${PUBLIC_IP:+x}" ]; then
    PUBLIC_IP=$(wget -qO- api.ipify.org)
fi

# Pin the leaf certificates nginx serves. Clients use these hashes
# (pinnedPeerCertSha256 / "pcs") instead of the removed "allowInsecure": they
# accept the exact cert regardless of trust store state, but the connection stays
# cryptographically verified. The hash is sha256 over the DER of the leaf cert,
# which is what Xray-core compares against.
# The certbot/openssl-cert services (dependencies of this one) guarantee the
# certs are in place before we reach this point.
compute_pinned_cert_sha256() {
    domain="$1"
    cert_file="${CERTBOT_LIVE_CERT_PATH}/${domain}/fullchain.pem"

    if [ ! -f "${cert_file}" ]; then
        echo "Expected certificate not found at ${cert_file}" >&2
        exit 1
    fi

    pinned_cert_sha256=$(
        openssl x509 -in "${cert_file}" -outform DER \
            | openssl dgst -sha256 \
            | sed 's/^.*= *//'
    )
    if [ ${#pinned_cert_sha256} -ne 64 ]; then
        echo "Failed to compute pinned cert SHA-256 for ${domain}" >&2
        exit 1
    fi

    echo "${pinned_cert_sha256}"
}

XRAY_XHTTP_PINNED_CERT_SHA256=$(compute_pinned_cert_sha256 "${XHTTP_DOMAIN}")
XRAY_XHTTP_SELF_PINNED_CERT_SHA256=$(compute_pinned_cert_sha256 "${XHTTP_SELF_DOMAIN}")
echo "Pinned XHTTP cert SHA-256: ${XRAY_XHTTP_PINNED_CERT_SHA256}"
echo "Pinned XHTTP self cert SHA-256: ${XRAY_XHTTP_SELF_PINNED_CERT_SHA256}"

CLIENT_CONFIG_PATH="${GENERATED_CONFIG_PATH}/clients"
# Remove any old generated configs
if [ -d "${CLIENT_CONFIG_PATH}" ]; then
    rm -rf "${CLIENT_CONFIG_PATH}"
fi
mkdir -p "${CLIENT_CONFIG_PATH}"
mkdir -p "${CLIENT_CONFIG_PATH}/json"
mkdir -p "${CLIENT_CONFIG_PATH}/yaml"


# loop over all files in data/clients
# Render each template into a throwaway copy instead of editing it in place, so
# the shipped templates keep their {{placeholders}}. This keeps generation
# idempotent: the certbot deploy-hook can re-run this script after a cert
# renewal to refresh the pinned cert hash.
for client in /etc/xray/clients/*.yaml; do
    client_name=$(basename "${client}" .yaml)
    rendered=$(mktemp)
    sed \
        -e "s|{{PUBLIC_IP}}|${PUBLIC_IP}|g" \
        -e "s|{{XHTTP_DOMAIN}}|${XHTTP_DOMAIN}|g" \
        -e "s|{{XHTTP_SELF_DOMAIN}}|${XHTTP_SELF_DOMAIN}|g" \
        -e "s|{{REALITY_DOMAIN}}|${REALITY_DOMAIN}|g" \
        -e "s|{{XRAY_UUID}}|${XRAY_UUID}|g" \
        -e "s|{{XRAY_REALITY_PUBLIC_KEY}}|${XRAY_REALITY_PUBLIC_KEY}|g" \
        -e "s|{{XRAY_REALITY_SHORT_ID}}|${XRAY_REALITY_SHORT_ID}|g" \
        -e "s|{{XRAY_XHTTP_PATH}}|${XRAY_XHTTP_PATH}|g" \
        -e "s|{{XRAY_XHTTP_PINNED_CERT_SHA256}}|${XRAY_XHTTP_PINNED_CERT_SHA256}|g" \
        -e "s|{{XRAY_XHTTP_SELF_PINNED_CERT_SHA256}}|${XRAY_XHTTP_SELF_PINNED_CERT_SHA256}|g" \
        -e "s|{{XRAY_VLESS_ENCRYPTION}}|${XRAY_VLESS_ENCRYPTION}|g" \
        "${client}" \
        > "${rendered}"

    yq eval-all \
        '.inbounds += (select(fi == 1).inbounds) | select(fi == 0)' \
        "${rendered}" \
        /config/inbound.yaml \
        -oj \
        > "${CLIENT_CONFIG_PATH}/json/${client_name}.json"
    yq eval-all \
        '.inbounds += (select(fi == 1).inbounds) | select(fi == 0)' \
        "${rendered}" \
        /config/inbound.yaml \
        -oy \
        > "${CLIENT_CONFIG_PATH}/yaml/${client_name}.yaml"

    rm -f "${rendered}"
done

configgen /etc/xray/client_uri.yaml -o /etc/xray/client_uri.txt
