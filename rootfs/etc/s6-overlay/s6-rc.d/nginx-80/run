#!/command/with-contenv sh
# shellcheck shell=sh

set -eou pipefail

echo "Starting nginx-80..."

NGINX_CONFIG="${PWD}/data/nginx.conf"

# Render the {{VAR}} placeholders in place (CERTBOT_CONFIG_PATH_WWW is exported
# by the container environment). render-env aborts if a referenced variable is
# unset or empty; --in-place keeps the file's permissions and inode.
render-env --in-place "${NGINX_CONFIG}"

exec s6-notifyoncheck -n 0 \
    nginx -g 'daemon off;' -c "${NGINX_CONFIG}"
