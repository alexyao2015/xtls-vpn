#!/usr/bin/env python3
"""render-env — substitute {{VAR}} placeholders with environment variables.

Reads the file given as the only argument, replaces every {{NAME}} placeholder
with the value of the matching environment variable, and writes the result to
stdout (or back to the file itself with --in-place).

Design notes:
- Format-agnostic: it works on raw text, so YAML, JSON, nginx configs, anything.
  The {{VAR}} delimiter collides with nothing -- crucially not with the
  $variables nginx and the shell use natively, which pass through untouched.
- Auto-discovery: every {{VAR}} is found by the regex, so adding a placeholder
  to a template needs no change here or in the calling script.
- Fail loud: an unset or empty variable is a hard error (exit 1), so callers
  under `set -e` abort instead of shipping a half-rendered config.
- Safe values: re.sub replaces via a function, so the value is inserted
  literally -- characters like & \\ / | can't corrupt the output the way they
  can on sed's replacement side.
- Idempotent: text with no {{...}} left is passed through unchanged.

Output:
- By default the result goes to stdout.
- `-i/--in-place` rewrites the input file itself. The whole file is read before
  it is rewritten, so this is safe and the original inode + permission bits are
  kept (the file is truncated and rewritten, not recreated) -- which is why
  callers don't need a `mktemp` + `cat` dance to render a config in place.

Variables are read from the process environment, so callers must export them
(e.g. `set -o allexport`) before invoking this utility.
"""

import os
import re
import sys
from typing import NoReturn

# {{NAME}} where NAME is a shell-style identifier (a letter or underscore
# followed by letters, digits or underscores). Anything else is left as-is.
PLACEHOLDER = re.compile(r"\{\{([A-Za-z_][A-Za-z0-9_]*)\}\}")


def fail(message: str) -> NoReturn:
    """Print an error to stderr and abort with a non-zero exit code."""
    print(f"render-env: {message}", file=sys.stderr)
    raise SystemExit(1)


def substitute(match: re.Match[str]) -> str:
    """Resolve a matched {{NAME}} to its env value, refusing unset/empty."""
    name = match.group(1)
    if name not in os.environ:
        fail(f"variable {name} is not set")
    value = os.environ[name]
    if not value:
        fail(f"variable {name} is empty")
    return value


def main() -> None:
    args = sys.argv[1:]
    in_place = False
    if args and args[0] in ("-i", "--in-place"):
        in_place = True
        args = args[1:]
    if len(args) != 1:
        fail("usage: render-env [-i|--in-place] FILE")
    path = args[0]

    # Read the whole file and rewrite every placeholder in a single pass.
    # Reading fully up front is what makes the in-place rewrite below safe.
    with open(path, encoding="utf-8") as handle:
        text = handle.read()

    rendered = PLACEHOLDER.sub(substitute, text)

    if in_place:
        # Opening the existing file with "w" truncates and rewrites it, keeping
        # the original inode and permission bits -- no temp file + cat needed.
        with open(path, "w", encoding="utf-8") as handle:
            handle.write(rendered)
    else:
        sys.stdout.write(rendered)


if __name__ == "__main__":
    main()
