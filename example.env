# Use self-signed certificate for testing
SELF_SIGNED_CERT="false"
LETSENCRYPT_STAGING="false"
# Automatically determined if empty
PUBLIC_IP=""

# No CDN
REALITY_DOMAIN=""
# CDN
XHTTP_DOMAIN=""
# No CDN, self-signed long-lived cert for the xhttp_self profile. This is only an
# SNI label + self-signed cert subject (pinned by the client), so it does NOT need
# to be a domain you own or that resolves in DNS. It MUST differ from REALITY_DOMAIN
# and XHTTP_DOMAIN so it falls through to nginx's catch-all default_server.
XHTTP_SELF_DOMAIN=""

XRAY_PATH="/my/very/long/path"

REALITY_DOMAIN_PROXY_SITE="www.example.com"
XHTTP_DOMAIN_PROXY_SITE="www.example.com"
